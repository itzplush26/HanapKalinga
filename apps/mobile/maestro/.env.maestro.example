# =============================================================================
# Maestro E2E Test Environment Configuration
# =============================================================================
# Copy this file to .env.maestro and fill in your values.
# NOTE: .env.maestro is gitignored — never commit secrets to the repo.
#
# Required setup:
#   1. Local Supabase: run `supabase start` for local dev, then:
#        - SUPABASE_URL_LOCAL: default is http://localhost:54321
#        - SUPABASE_SERVICE_ROLE_KEY_LOCAL: get from `supabase status`
#   2. Staging Supabase: get from Supabase Dashboard > Settings > API
#        - SUPABASE_URL_STAGING: your project URL
#        - SUPABASE_SERVICE_ROLE_KEY_STAGING: service_role key (keep secret!)
# =============================================================================

# Runtime environment - set to "local" or "staging"
ENV=local

# App identifiers
APP_ID_LOCAL=host.exp.Exponent
APP_ID_STAGING=com.hanapkalinga.mobile

# Supabase (override via CI secrets)
SUPABASE_URL_LOCAL=http://localhost:54321
SUPABASE_URL_STAGING=https://YOUR-PROJECT.supabase.co

# Service role keys (admin access - required by seed scripts)
# Local: run "supabase status" to find your service_role key
# Staging: get from Supabase Dashboard > Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY_LOCAL=your-local-service-role-key-here
SUPABASE_SERVICE_ROLE_KEY_STAGING=your-staging-service-role-key-here

# Seed test account credentials
TEST_EMAIL_PREFIX=e2e-test
TEST_PASSWORD=TestPass123!
